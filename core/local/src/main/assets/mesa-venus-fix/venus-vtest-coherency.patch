+/* HVN venus host-visible coherency: vtest maps app memory as MAP_SHARED of a
+ * host3d dma-buf blob and advertises it HOST_COHERENT, but on ARM the guest
+ * CPU's cached writes are not written back to the dma-buf before the Mali GPU
+ * reads it -> intermittently stale per-frame uniforms/streamed vertex data
+ * (the windowed-GL flicker). Clean the guest dcache to PoC over mapped ranges
+ * before each submit so the GPU sees the latest guest writes. */
+#if defined(__aarch64__)
+static void
+hvn_dcache_clean(const void *addr, size_t size)
+{
+   static uintptr_t cl = 0;
+   if (!cl) {
+      uint64_t ctr;
+      __asm__ volatile("mrs %0, ctr_el0" : "=r"(ctr));
+      cl = (uintptr_t)4u << ((ctr >> 16) & 0xf);
+   }
+   uintptr_t p = (uintptr_t)addr & ~(cl - 1);
+   uintptr_t end = (uintptr_t)addr + size;
+   for (; p < end; p += cl)
+      __asm__ volatile("dc cvac, %0" ::"r"(p) : "memory");
+   __asm__ volatile("dsb sy" ::: "memory");
+}
+#else
+static void hvn_dcache_clean(const void *a, size_t s) { (void)a; (void)s; }
+#endif
 
